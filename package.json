{
  "name": "@sio/forms",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:types": "npm run build --workspace=@sio/form-types",
    "build:builder": "npm run build --workspace=@sio/form-builder",
    "build:react": "npm run build --workspace=@sio/form-react",
    "build:validation": "npm run build --workspace=@sio/form-validation",
    "build": "npm run build:types && npm run build:builder && npm run build:validation && npm run build:react",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\" --ext .ts,.tsx",
    "lint:fix": "eslint \"packages/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
